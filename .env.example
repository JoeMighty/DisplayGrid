# ─── Server URLs ──────────────────────────────────────────────────────────────
# Never use localhost — use your LAN IP or mDNS hostname.
# Display clients connect over the network, not loopback.
NEXTAUTH_URL=http://displaygrid.local:3000
NEXT_PUBLIC_APP_URL=http://displaygrid.local:3000
NEXT_PUBLIC_WS_URL=ws://displaygrid.local:3001

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generated automatically by install.sh — do not share this value.
NEXTAUTH_SECRET=

# ─── Ports ────────────────────────────────────────────────────────────────────
WS_PORT=3001

# ─── Paths ────────────────────────────────────────────────────────────────────
# Relative to repo root. Created at install. Never committed.
DB_PATH=../../data/displaygrid.db
UPLOAD_PATH=../../data/uploads

# ─── Image compression defaults ───────────────────────────────────────────────
# Adjustable at runtime via Settings > Compression (super_admin only).
DEFAULT_IMAGE_QUALITY=90
DEFAULT_IMAGE_FORMAT=webp
DEFAULT_IMAGE_MAX_WIDTH=3840
DEFAULT_IMAGE_MAX_HEIGHT=2160
