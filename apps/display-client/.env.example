# DisplayGrid Display Client — environment variables
# Copy this file to .env.local and fill in your values.

# Base URL of the DisplayGrid dashboard server (no trailing slash)
# For same-machine dev:    http://displaygrid.test:3000
# For network kiosk:       http://192.168.1.10:3000   (replace with server IP)
VITE_API_BASE=http://displaygrid.test:3000

# WebSocket server URL
# For same-machine dev:    ws://displaygrid.test:3001
# For network kiosk:       ws://192.168.1.10:3001
VITE_WS_BASE=ws://displaygrid.test:3001

# Optional: pre-configure a screen token to skip the token entry screen on boot
# Get the token from the dashboard: Screens → your screen → Copy Token
# VITE_SCREEN_TOKEN=your-screen-token-here
