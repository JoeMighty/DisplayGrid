# Use a flat (npm-style) node_modules layout with no symlinks.
# pnpm's default virtual-store layout (symlinks into .pnpm/) does not survive
# the GitHub artifact pipeline on Windows or NSIS packaging.  hoisted layout
# writes every package as a real directory, removing all symlink-related issues.
node-linker=hoisted

# Hoist CSS tooling to root so Next.js (running from monorepo root) can resolve it
# (redundant with hoisted but kept for clarity)
public-hoist-pattern[]=*tailwindcss*
public-hoist-pattern[]=*autoprefixer*
public-hoist-pattern[]=*postcss*
